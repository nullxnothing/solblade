{
  "name": "solblade",
  "version": "0.1.0",
  "description": "AI-native Solana wallet CLI. Sharp. Fast. AI-Native.",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "solblade": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --compile",
    "postinstall": "echo 'Run: solblade init'"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3"
  }
}
